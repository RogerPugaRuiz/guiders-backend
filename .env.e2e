# =======================================================
# .env.e2e — Entorno efímero para tests E2E en CI
# =======================================================
# ADVERTENCIA: Estas credenciales son PÚBLICAS a propósito.
# Este archivo está diseñado para correr en un contenedor Docker
# efímero dentro de GitHub Actions. NUNCA usar en producción.
# =======================================================

NODE_ENV=test
PORT=3099
DEBUG=false

# Sincronizar schema TypeORM directamente desde entidades (evita migraciones rotas en E2E)
TYPEORM_SYNC=true

# -------------------------------------------------------
# PostgreSQL
# -------------------------------------------------------
DATABASE_HOST=postgres-e2e
DATABASE_PORT=5432
DATABASE_USERNAME=e2e
DATABASE_PASSWORD=e2e
DATABASE=guiders_e2e

# En NODE_ENV=test app.module usa TEST_DATABASE_* para TypeORM también
TEST_DATABASE_HOST=postgres-e2e
TEST_DATABASE_PORT=5432
TEST_DATABASE_USERNAME=e2e
TEST_DATABASE_PASSWORD=e2e
TEST_DATABASE=guiders_e2e

# -------------------------------------------------------
# MongoDB (sin auth — NODE_ENV=test permite conexión sin credenciales)
# -------------------------------------------------------
MONGODB_HOST=mongodb-e2e
MONGODB_PORT=27017
MONGODB_DATABASE=guiders_e2e

TEST_MONGODB_HOST=mongodb-e2e
TEST_MONGODB_PORT=27017
TEST_MONGODB_DATABASE=guiders_e2e

# -------------------------------------------------------
# Redis
# -------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://redis-e2e:6379

# -------------------------------------------------------
# Auth / Tokens
# -------------------------------------------------------
ENCRYPTION_KEY=e2e00000000000000000000000000000000000000000000000000000000000001
GLOBAL_TOKEN_SECRET=e2e_global_token_secret_for_ci_only
ACCESS_TOKEN_EXPIRATION=24h
REFRESH_TOKEN_EXPIRATION=30d
JWKS_BASE_URL=http://localhost:3099

# -------------------------------------------------------
# Email (deshabilitado en E2E)
# -------------------------------------------------------
RESEND_API_KEY=re_e2e_disabled
EMAIL_FROM=e2e@guiders.local

# -------------------------------------------------------
# URLs
# -------------------------------------------------------
APP_URL=http://localhost:3099
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201,http://localhost:3099

# -------------------------------------------------------
# LLM (deshabilitado)
# -------------------------------------------------------
LLM_ENABLED=false
LLM_PROVIDER=none

# -------------------------------------------------------
# Keycloak / OIDC
# -------------------------------------------------------
KEYCLOAK_ISSUER=http://localhost:3099/realms/e2e
KEYCLOAK_JWKS_URI=http://localhost:3099/realms/e2e/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=account
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=guiders
KEYCLOAK_CLIENT_ID=console
OIDC_ISSUER=http://localhost:3099/realms/e2e
OIDC_CONSOLE_CLIENT_ID=console
OIDC_CONSOLE_REDIRECT_URI=http://localhost:3099/api/bff/auth/callback/console
OIDC_ADMIN_CLIENT_ID=admin
OIDC_ADMIN_REDIRECT_URI=http://localhost:3099/api/bff/auth/callback/admin

# -------------------------------------------------------
# Cookies / BFF
# -------------------------------------------------------
SAMESITE=lax
COOKIE_SECURE=false
COOKIE_PATH=/
REFRESH_PATH=/api/bff/auth/refresh
ALLOW_RETURN_TO=http://localhost:4200,http://localhost:4201
SESSION_COOKIE_CONSOLE=console_session_e2e
REFRESH_COOKIE_CONSOLE=console_refresh_e2e
SESSION_COOKIE_ADMIN=admin_session_e2e
REFRESH_COOKIE_ADMIN=admin_refresh_e2e

# -------------------------------------------------------
# Credenciales E2E conocidas — usadas por el seed y los tests
# -------------------------------------------------------
E2E_ADMIN_EMAIL=admin@e2e.guiders.local
E2E_ADMIN_PASSWORD=E2eAdmin123!
E2E_COMPANY_NAME=Guiders E2E Test Company
E2E_DOMAIN=e2e.guiders.local
